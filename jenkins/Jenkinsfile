pipeline {
    agent any

    environment {
        DOCKER_USERNAME = credentials('docker-username')
        DOCKER_PASSWORD = credentials('docker-password')

        IMAGE_NAME = "${DOCKER_USERNAME}/devops-lab-app"
        VERSION = "v${BUILD_NUMBER}"

        GITOPS_REPO = "https://github.com/KissMeRight/finalmobile68.git"
        GIT_CREDENTIALS_ID = 'github-token'
    }

    triggers {
        pollSCM('H/1 * * * *')
    }

    stages {

        stage('Checkout') {
            steps {
                echo "📥 Checking out source code..."
                git branch: 'main', url: "${GITOPS_REPO}"
            }
        }

        stage('Build Image') {
            steps {
                echo "🔨 Building Docker image..."

                bat """
                    docker build ^
                        --build-arg APP_VERSION=%VERSION% ^
                        -t %IMAGE_NAME%:%VERSION% ^
                        -t %IMAGE_NAME%:latest ^
                        ./backend
                """
            }
        }

        stage('Test') {
            steps {
                echo "🧪 Running tests..."

                bat """
                    docker run --rm %IMAGE_NAME%:%VERSION% ^
                        cmd /c "cd /app && node -e \"console.log('Tests passed ✅')\""
                """
            }
        }

        stage('Push Image') {
            steps {
                echo "📤 Pushing image..."

                bat """
                    echo %DOCKER_PASSWORD% | docker login -u %DOCKER_USERNAME% --password-stdin
                    docker push %IMAGE_NAME%:%VERSION%
                    docker push %IMAGE_NAME%:latest
                """
            }
        }

        stage('Update Manifest') {
            steps {
                echo "📝 Updating GitOps repo..."

                withCredentials([string(credentialsId: 'github-token', variable: 'GIT_TOKEN')]) {

                    bat """
                        git clone https://%GIT_TOKEN%@github.com/KissMeRight/finalmobile68.git gitops
                        cd gitops

                        powershell -Command "(Get-Content k8s\\green\\deployment.yaml) -replace 'image:.*devops-lab-app.*', 'image: %IMAGE_NAME%:%VERSION%' | Set-Content k8s\\green\\deployment.yaml"

                        git config user.email "jenkins@devops-lab.com"
                        git config user.name "Jenkins CI"

                        git add k8s\\green\\deployment.yaml
                        git commit -m "ci: update image %VERSION% [build #%BUILD_NUMBER%]"
                        git push origin main
                    """
                }
            }
        }

        stage('Done') {
            steps {
                echo """
================================================
✅ PIPELINE SUCCESS
Image: ${IMAGE_NAME}:${VERSION}
ArgoCD will deploy automatically
================================================
"""
            }
        }
    }

    post {
        always {
            bat "docker rmi %IMAGE_NAME%:%VERSION% || exit 0"
        }

        success {
            echo "🎉 SUCCESS: ${VERSION}"
        }

        failure {
            echo "❌ FAILED: Check logs"
        }
    }
}